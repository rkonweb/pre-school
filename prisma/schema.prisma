  respondedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@index([parentMobile])
}

model SchoolCircular {
  id             String    @id @default(cuid())
  schoolId       String
  title          String
  content        String?
  fileUrl        String?
  type           String    @default("CIRCULAR")
  targetClassIds String    @default("[]")
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([isPublished])
  @@index([publishedAt])
}

model PTMSession {
  id          String       @id @default(cuid())
  schoolId    String
  title       String
  description String?
  date        DateTime
  slotMinutes Int          @default(10)
  startTime   String
  endTime     String
  classIds    String       @default("[]")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  bookings    PTMBooking[]
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([date])
}

model PTMBooking {
  id           String     @id @default(cuid())
  sessionId    String
  studentId    String
  parentMobile String
  teacherName  String?
  slotTime     String
  status       String     @default("CONFIRMED")
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  session      PTMSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, slotTime, teacherName])
  @@index([sessionId])
  @@index([studentId])
  @@index([parentMobile])
}

model ParentStoreItem {
  id          String                 @id @default(cuid())
  schoolId    String
  name        String
  description String?
  price       Float
  imageUrl    String?
  category    String                 @default("UNIFORM")
  stock       Int                    @default(0)
  isAvailable Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  school      School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  orderItems  ParentStoreOrderItem[]

  @@index([schoolId])
  @@index([isAvailable])
  @@index([category])
}

model ParentStoreOrder {
  id           String                 @id @default(cuid())
  schoolId     String
  studentId    String
  parentMobile String
  status       String                 @default("PLACED")
  totalAmount  Float
  notes        String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  payment      OnlinePaymentRequest?
  school       School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  items        ParentStoreOrderItem[]

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@index([parentMobile])
}

model ParentStoreOrderItem {
  id        String           @id @default(cuid())
  orderId   String
  itemId    String
  quantity  Int
  unitPrice Float
  item      ParentStoreItem  @relation(fields: [itemId], references: [id])
  order     ParentStoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([itemId])
}

model OnlinePaymentRequest {
  id               String            @id @default(cuid())
  schoolId         String
  studentId        String
  parentMobile     String
  type             String
  amount           Float
  description      String
  status           String            @default("PENDING")
  feeId            String?
  storeOrderId     String?           @unique
  gatewayOrderId   String?
  gatewayPaymentId String?
  paidAt           DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  school           School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  storeOrder       ParentStoreOrder? @relation(fields: [storeOrderId], references: [id])
  student          Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@index([parentMobile])
}

// ==========================================
// HOSTEL MODULE
// ==========================================

model Hostel {
  id           String       @id @default(cuid())
  name         String
  capacity     Int          @default(0)
  gender       String       @default("COED")
  address      String?
  managerName  String?
  managerPhone String?
  schoolId     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rooms        HostelRoom[]

  @@index([schoolId])
}

model HostelRoom {
  id          String             @id @default(cuid())
  roomNumber  String
  floor       String?
  capacity    Int                @default(1)
  roomType    String             @default("STANDARD")
  amenities   String             @default("[]")
  baseCost    Float              @default(0)
  hostelId    String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  hostel      Hostel             @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  allocations HostelAllocation[]

  @@index([hostelId])
}

model HostelAllocation {
  id         String     @id @default(cuid())
  studentId  String
  roomId     String
  monthlyFee Float      @default(0)
  startDate  DateTime   @default(now())
  endDate    DateTime?
  status     String     @default("ACTIVE")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  room       HostelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([roomId])
}

// ==========================================
// CANTEEN MODULE
// ==========================================

model CanteenPackage {
  id             String                @id @default(cuid())
  name           String
  description    String?
  includedMeals  String
  monthlyFee     Float
  yearlyFee      Float
  packageType    String
  isActive       Boolean               @default(true)
  schoolId       String
  school         School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subscriptions  CanteenSubscription[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([schoolId])
}

model CanteenItem {
  id            String             @id @default(cuid())
  name          String
  description   String?
  category      String             @default("[]")
  mealType      String
  dietType      String?
  price         Float
  isAddOn       Boolean            @default(false)
  foodCategory  String?
  gstPercentage Float?             @default(0)
  hsnCode       String?
  isAvailable   Boolean            @default(true)
  schoolId      String
  school        School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  orderItems    CanteenOrderItem[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([schoolId])
}

model CanteenMenuPlan {
  id             String   @id @default(cuid())
  schoolId       String
  dayOfWeek      Int
  mealType       String
  items          String   @default("[]")
  isSpecial      Boolean  @default(false)
  specialDetails String?
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([schoolId, dayOfWeek, mealType])
}

model CanteenSubscription {
  id           String         @id @default(cuid())
  studentId    String
  packageId    String
  billingCycle String
  feeAmount    Float
  startDate    DateTime       @default(now())
  endDate      DateTime?
  status       String         @default("ACTIVE")
  schoolId     String
  school       School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  package      CanteenPackage @relation(fields: [packageId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([schoolId])
  @@index([studentId])
}

model StudentWallet {
  id           String              @id @default(cuid())
  studentId    String              @unique
  schoolId     String
  balance      Float               @default(0)
  school       School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([schoolId])
}

model WalletTransaction {
  id             String         @id @default(cuid())
  walletId       String
  type           String
  amount         Float
  reason         String
  description    String?
  canteenOrderId String?
  wallet         StudentWallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  canteenOrder   CanteenOrder?  @relation(fields: [canteenOrderId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([walletId])
}

model CanteenOrder {
  id             String             @id @default(cuid())
  studentId      String
  totalAmount    Float
  subtotal       Float
  taxAmount      Float              @default(0)
  paymentMethod  String
  subscriptionId String?
  notes          String?
  status         String             @default("COMPLETED")
  orderDate      DateTime           @default(now())
  student        Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  orderItems     CanteenOrderItem[]
  transactions   WalletTransaction[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([studentId])
  @@index([orderDate])
}

model CanteenOrderItem {
  id        String       @id @default(cuid())
  orderId   String
  itemId    String
  quantity  Int
  price     Float
  taxAmount Float        @default(0)
  hsnCode   String?
  item      CanteenItem  @relation(fields: [itemId], references: [id])
  order     CanteenOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([itemId])
}

model FoodCategory {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  credentialID String   @unique 
  publicKey    Bytes    
  counter      BigInt   
  transports   String?  
  fingerName   String?
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  
  @@index([userId])
}

// -------------------------------------------------------------------------------------
// 19. AUDIT & LOGGING
// -------------------------------------------------------------------------------------

model AuditLog {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action       String   // e.g., "LOGIN", "LOGOUT", "CREATE_STUDENT", "DELETE_STAFF"
  entityType   String?  // e.g., "Student", "Staff", "Settings"
  entityId     String?
  details      Json?    // Stores changes, IP address, user agent, etc.
  riskScore    Int      @default(0) // AI assigned risk score (0-100)
  isSuspicious Boolean  @default(false)
  aiAnalysis   String?  // Explains why it was flagged
  createdAt    DateTime @default(now())

  @@index([schoolId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// -------------------------------------------------------------------------------------
// 20. EXTRACURRICULAR ACTIVITIES
// -------------------------------------------------------------------------------------

model Activity {
  id               String       @id @default(cuid())
  name             String
  category         String       // Sports, Arts, Club, Skill
  description      String?
  ageGroup         String?
  gender           String?      // Optional gender restriction
  maxStudents      Int?
  level            String?      // Beginner, Intermediate, Advanced
  frequency        String?      // Weekly, Daily, Seasonal, Event-based
  duration         String?      // e.g., "1 hour"
  venue            String?
  coachId          String?
  coach            User?        @relation("ActivityCoach", fields: [coachId], references: [id])
  schedule         String?
  fee              Float?       @default(0)
  startDate        DateTime?
  endDate          DateTime?
  equipment        String?      // Suggested equipment
  status           String       @default("ACTIVE") // ACTIVE, UPCOMING, CLOSED
  schoolId         String
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  enrollments      ActivityEnrollment[]
  timetable        ActivityTimetable[]
  sessions         ActivitySession[]
  performanceRecords ActivityPerformance[]
  awards           ActivityAward[]
  fees             ActivityFee[]

  @@index([schoolId])
  @@index([category])
}

model Club {
  id               String       @id @default(cuid())
  name             String
  description      String?
  coachId          String?
  coach            User?        @relation("ClubCoach", fields: [coachId], references: [id])
  capacity         Int?
  logo             String?
  meetingSchedule  String?      // e.g., "Saturdays 10 AM"
  schoolId         String
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([schoolId])
}

model ActivityEnrollment {
  id               String       @id @default(cuid())
  studentId        String
  student          Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  activityId       String
  activity         Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  skillLevel       String?      // Beginner, Developing, Skilled, Advanced
  medicalRestrictions String?
  parentApproval   Boolean      @default(false)
  status           String       @default("PENDING") // PENDING, APPROVED, WAITLISTED
  schoolId         String
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([studentId, activityId])
  @@index([schoolId])
}

model ActivityTimetable {
  id               String       @id @default(cuid())
  activityId       String
  activity         Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  dayOfWeek        String       // MONDAY, TUESDAY, etc.
  startTime        String
  endTime          String
  venue            String?
  coachId          String?
  coach            User?        @relation("TimetableCoach", fields: [coachId], references: [id])
  schoolId         String
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([schoolId])
  @@index([activityId])
}

model ActivitySession {
  id               String       @id @default(cuid())
  activityId       String
  activity         Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  date             DateTime
  coachId          String?
  coach            User?        @relation("SessionCoach", fields: [coachId], references: [id])
  location         String?
  notes            String?
  schoolId         String
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  attendance       ActivityAttendance[]

  @@index([schoolId])
  @@index([activityId])
  @@index([date])
}

model ActivityAttendance {
  id               String       @id @default(cuid())
  sessionId        String
  session          ActivitySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId        String
  student          Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status           String       // PRESENT, ABSENT, LATE, EXCUSED
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([sessionId, studentId])
}

model ActivityPerformance {
  id               String       @id @default(cuid())
  activityId       String
  activity         Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  studentId        String
  student          Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skillRating      Int?         // 1-5
  comments         String?
  achievements     String?
  level            String?      // Current level: Beginner -> Developing -> Skilled -> Advanced
  coachRemarks     String?
  schoolId         String
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([schoolId])
  @@index([activityId])
  @@index([studentId])
}

model ActivityEvent {
  id               String       @id @default(cuid())
  name             String
  type             String       // INTERNAL, INTER_SCHOOL, NATIONAL
  date             DateTime
  venue            String?
  participants     Json?        // List of participant IDs
  results          Json?        // Result documentation
  certificates     Json?        // Certificate links
  schoolId         String
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([schoolId])
}

model ActivityAward {
  id               String       @id @default(cuid())
  studentId        String
  student          Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  activityId       String
  activity         Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  awardType        String       // TROPHY, MEDAL, CERTIFICATE
  level            String       // SCHOOL, DISTRICT, STATE, NATIONAL
  certificateUrl   String?
  schoolId         String
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([schoolId])
}

model ActivityEquipment {
  id               String       @id @default(cuid())
  name             String
  quantity         Int
  location         String?
  condition        String?      // NEW, GOOD, FAIR, POOR, BROKEN
  maintenanceSchedule String?
  schoolId         String
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([schoolId])
}

model ActivityFee {
  id               String       @id @default(cuid())
  activityId       String
  activity         Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  studentId        String
  student          Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount           Float
  billingFrequency String       // MONTHLY, SEMESTER, ONE_TIME
  status           String       @default("PENDING") // PENDING, PAID, PARTIAL
  schoolId         String
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([schoolId])
}
